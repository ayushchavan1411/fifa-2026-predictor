# ---------- LOAD LOCAL DATA ----------
@st.cache_data
def load_worldcup_data():
    """Load World Cup 2026 data from local JSON file."""
    try:
        with open('data/worldcup.json/2026/worldcup.json', 'r') as f:
            return json.load(f)
    except FileNotFoundError:
        st.error("World Cup data file not found. Please ensure data/worldcup.json/2026/worldcup.json exists.")
        return None

@st.cache_data
def load_player_profiles():
    """Load player profiles from CSV."""
    try:
        df = pd.read_csv('data/player_data/datalake/transfermarkt/player_profiles/player_profiles.csv')
        return df
    except FileNotFoundError:
        st.warning("Player profiles data not found. Player search will use mock data.")
        return pd.DataFrame()

# Load data once
WORLDCUP_DATA = load_worldcup_data()
PLAYER_DF = load_player_profiles()

# Extract groups and matches from the loaded data
def get_groups_from_data():
    """Return group mappings from the worldcup data."""
    if WORLDCUP_DATA is None:
        return {}
    groups = {}
    # The structure may vary; parse based on observed keys
    # In the openfootball format, groups are under 'groups' key
    for group in WORLDCUP_DATA.get('groups', []):
        group_name = group.get('group', 'Unknown')
        teams = group.get('teams', [])
        groups[group_name] = teams
    return groups

def get_matches_from_data():
    """Return list of matches from the worldcup data."""
    if WORLDCUP_DATA is None:
        return []
    matches = WORLDCUP_DATA.get('matches', [])
    # Each match should have home_team, away_team, group, status, home_score, away_score, date
    return matches

# Cache these to avoid recomputation
@st.cache_data
def get_cached_groups():
    return get_groups_from_data()

@st.cache_data
def get_cached_matches():
    return get_matches_from_data()

